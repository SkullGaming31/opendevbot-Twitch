{
  "name": "opendevbot-twitch",
  "version": "0.0.9",
  "description": "OpenDevBot Twitch Chatbot from scratch using Twitch API, EventSub, and OAuth2",
  "main": "dist/electron/main.js",
  "keywords": [],
  "author": "SkullGaming31",
  "license": "MIT",
  "scripts": {
    "start": "node .",
    "dev": "nodemon ./src/index.ts",
    "build": "tsc",
    "start:electron": "npm run build && electron .",
    "dev:electron": "npm run build && electron . --disable-gpu --disable-gpu-compositing --disable-software-rasterizer --disable-accelerated-2d-canvas --disable-accelerated-video-decode --disable-accelerated-video --disable-gpu-sandbox --no-sandbox",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^0.14.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/eslint": "^9.6.1",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.10.1",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.15",
    "electron": "^43.0.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  },
  "vitest": {
    "setupFiles": [
      "src/test-setup.ts"
    ]
  }
}