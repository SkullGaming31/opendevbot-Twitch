# Twitch App credentials
# Your Twitch application Client ID (required for Helix API calls)
CLIENT_ID=
# Your Twitch application Client Secret (keep this secret, don't commit real secrets)
CLIENT_SECRET=
# OAuth redirect URL you've registered for the app
REDIRECT_URI=http://localhost:3001/api/v1/auth/twitch/callback

# MongoDB connection helpers (dev/CI)
# Optional: a username/password for building a connection string
MONGODB_USERNAME=
MONGODB_PASSWORD=
# Local Docker/mongo connection used in dev workflows (example: mongodb://localhost:27017/opendevbot-twitch)
DOCKER_URI=mongodb://localhost:27017/opendevbot-twitch
# Canonical MongoDB connection string (can be a SRV string)
MONGODB_URI=

# Environment name (dev, staging, production). Some logic prefers DOCKER_URI in dev.
ENVIRONMENT=dev

# Chat / Bot configuration
# The bot's login (lowercase) used as the IRC nick
CHAT_BOT_NICK=opendevbot
# If true, the manager will perform auto-join for channels discovered in the DB
CHAT_AUTOJOIN=true
# Enable the chat manager and start the bot connection
CHAT_ENABLED=true
# The bot account's Twitch user id (used to load token from DB if CHAT_BOT_OAUTH not set)
CHAT_BOT_USER_ID=
# If you prefer to supply the OAuth token directly, set CHAT_BOT_OAUTH to 'oauth:<access_token>'
CHAT_BOT_OAUTH=

# Debugging/Logging
# When true, raw IRC payloads are printed to stdout via console.debug (helps debug connection/parsing)
CHAT_DEBUG_RAW=false
# When true, pino's console transport is enabled so logs print to stdout
LOG_TO_CONSOLE=false
# When true, include the full parsed message object in chat logs
CHAT_LOG_FULL=false

# Optional feature flags / tuning
# Per-channel rate limit window in milliseconds (defaults inside code to 30000)
PER_CHANNEL_WINDOW_MS=30000
# Per-channel capacity (small bucket) default 20
PER_CHANNEL_CAPACITY=20
# Privileged capacity default 100
PRIVILEGED_CAPACITY=100
# Copy this file to .env and fill in real values (do NOT commit .env)

# MongoDB connection strings (choose one):
# For local Docker-based development (no username/password required), set `DOCKER_URI`:
DOCKER_URI=mongodb://localhost:27017/opendevbot_twitch

# For a cloud / Atlas connection use `MONGODB_URI` (mongodb+srv) and include credentials
# Example (URL-encode special characters in the password):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# `MONGO_URI` is the canonical setting used in production if present:
MONGO_URI=mongodb atlas connection string here

# Twitch app credentials
CLIENT_ID=your_twitch_client_id
CLIENT_SECRET=your_twitch_client_secret
REDIRECT_URI=http://localhost:3001/api/v1/auth/twitch/callback

# EventSub secret used to verify webhooks
EVENTSUB_SECRET=your_random_eventsub_secret

# Other
PORT=3001
ENVIRONMENT=dev | debug | prod