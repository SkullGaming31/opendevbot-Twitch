# Copy this file to .env and fill in real values (do NOT commit .env)

# MongoDB connection strings (choose one):
# For local Docker-based development (no username/password required), set `DOCKER_URI`:
DOCKER_URI=mongodb://localhost:27017/opendevbot_twitch

# For a cloud / Atlas connection use `MONGODB_URI` (mongodb+srv) and include credentials
# Example (URL-encode special characters in the password):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# `MONGO_URI` is the canonical setting used in production if present:
MONGO_URI=mongodb atlas connection string here

# Twitch app credentials
CLIENT_ID=your_twitch_client_id
CLIENT_SECRET=your_twitch_client_secret
REDIRECT_URI=http://localhost:3001/api/v1/auth/twitch/callback

# EventSub secret used to verify webhooks
EVENTSUB_SECRET=your_random_eventsub_secret

# Other
PORT=3001
ENVIRONMENT=dev | debug | prod